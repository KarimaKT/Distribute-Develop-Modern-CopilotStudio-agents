{
  "powerPlatform.experimental.pacDirectory": "",
  "files.associations": {
    "*.mcs.yml": "yaml"
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/microsoft/PowerApps-Tooling/main/src/PAModel/Schemas/mcs/mcs-schema.json": "*.mcs.yml"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "search.exclude": {
    "_workspace_*/**": true,
    "_inspect_*/**": true,
    "_skill_build/**": true
  }
}
